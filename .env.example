# Environment
NODE_ENV=development
PORT=4401

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/opennotify

# Redis (for caching and queues)
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# ============================================
# SMS PROVIDERS
# ============================================

# Eskiz
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
ESKIZ_CALLBACK_URL=
ESKIZ_TEST_MODE=true

# PlayMobile
PLAYMOBILE_USERNAME=
PLAYMOBILE_PASSWORD=
PLAYMOBILE_ORIGINATOR=
PLAYMOBILE_TEST_MODE=true

# GetSMS
GETSMS_LOGIN=
GETSMS_PASSWORD=
GETSMS_TEST_MODE=true

# ============================================
# TELEGRAM
# ============================================

# Telegram Bot (клиент добавляет свой токен через dashboard)
# Это для системного бота (опционально)
TELEGRAM_SYSTEM_BOT_TOKEN=

# ============================================
# EMAIL PROVIDERS
# ============================================

# SMTP (generic)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=

# SendGrid
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# Mailgun
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_FROM_EMAIL=

# ============================================
# PUSH NOTIFICATIONS
# ============================================

# Firebase FCM
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# Apple APNs
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_PRIVATE_KEY=
APNS_BUNDLE_ID=

# ============================================
# WHATSAPP (Phase 2)
# ============================================

# WhatsApp Business API
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# ============================================
# SECURITY
# ============================================

# Webhook secrets (for signature verification)
WEBHOOK_SECRET=your-webhook-secret-key

# Encryption key for provider credentials
CREDENTIALS_ENCRYPTION_KEY=your-32-char-encryption-key-here

# ============================================
# OTP SERVICE
# ============================================

# OTP Configuration
OTP_CODE_LENGTH=6
OTP_EXPIRY_SECONDS=300
OTP_MAX_ATTEMPTS=3
OTP_FALLBACK_DELAY_SECONDS=30
