{
    "name": "opennotify/opennotify-php",
    "description": "PHP SDK for OpenNotify - Unified Notification API for Central Asia",
    "version": "0.1.0",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "notifications",
        "sms",
        "telegram",
        "email",
        "push",
        "whatsapp",
        "opennotify",
        "uzbekistan",
        "central-asia"
    ],
    "authors": [
        {
            "name": "OpenNotify",
            "email": "dev@opennotify.dev"
        }
    ],
    "homepage": "https://opennotify.dev",
    "require": {
        "php": ">=8.0",
        "guzzlehttp/guzzle": "^7.0",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "php-parallel-lint/php-parallel-lint": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "OpenNotify\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OpenNotify\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "lint": "parallel-lint src tests"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
