{
    "name": "@opennotify/node-sdk",
    "version": "0.1.0",
    "description": "OpenNotify Node.js SDK - Unified notification API for SMS, Telegram, Email, Push",
    "author": "Fozilbek Samiyev <fozilbek.samiyev@gmail.com>",
    "license": "MIT",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "README.md"
    ],
    "scripts": {
        "build": "tsc",
        "clean": "rm -rf dist",
        "test": "vitest",
        "test:run": "vitest run",
        "prepublishOnly": "pnpm build"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "devDependencies": {
        "typescript": "^5.7.2",
        "vitest": "^2.1.8"
    },
    "keywords": [
        "opennotify",
        "notifications",
        "sms",
        "telegram",
        "email",
        "push",
        "whatsapp",
        "eskiz",
        "uzbekistan",
        "otp"
    ],
    "homepage": "https://opennotify.dev"
}
